# Secrets & service accounts (do NOT commit these)
.env
.env.*
*.pem
*-firebase-adminsdk-*.json
firebase-adminsdk*.json
serviceAccount*.json
*-service-account*.json
google-services.json
GoogleService-Info.plist

# Keep example/template files
!.env.example
!google-services.example.json

# Supabase CLI temp files (contains project ref & pooler URL)
supabase/.temp/

# IDE / editor local config
.idea/
.claude/settings.local.json

# Local planning/building docs (kept private, not in public repo)
docs/

# Qoder IDE generated docs & knowledge (auto-generated, keep local)
.qoder/
