{
  "name": "homestox",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:go": "expo start --go",
    "start:dev-client": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "type-check": "tsc --noEmit",
    "type-check:test": "tsc --noEmit -p tsconfig.test.json",
    "validate": "npm run type-check && npm run type-check:test",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:preview": "npx eas-cli build -p android --profile preview",
    "build:prod": "npx eas-cli build -p android --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.12.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/query-async-storage-persister": "^5.90.22",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-persist-client": "^5.90.22",
    "date-fns": "^4.1.0",
    "expo": "^55.0.26",
    "expo-build-properties": "~55.0.14",
    "expo-dev-client": "~55.0.35",
    "expo-device": "~55.0.17",
    "expo-font": "~55.0.8",
    "expo-linear-gradient": "~55.0.14",
    "expo-notifications": "~55.0.23",
    "expo-status-bar": "~55.0.6",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-paper": "^5.15.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "eas-cli": "^18.0.1",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.2",
    "vitest": "^4.1.9"
  },
  "private": true
}
